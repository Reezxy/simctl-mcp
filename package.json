{
  "name": "ios-simulator-mcp",
  "version": "0.1.0",
  "description": "MCP server for autonomous iOS simulator testing with Claude",
  "main": "dist/src/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.cjs",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.cjs --watch",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "sharp": "^0.33.0",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "fastest-levenshtein": "^1.0.16",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/sharp": "^0.31.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
